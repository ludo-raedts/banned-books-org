exports[`BanTimeline > renders a Mein-Kampf-like spread with active bans and mixed action types 1`] = `"<figure role="group" aria-labelledby="ban-timeline-title" class="not-prose mb-6 rounded-xl border border-gray-200 bg-white overflow-hidden"><h3 id="ban-timeline-title" class="sr-only">Ban timeline</h3><div class="grid grid-cols-[max-content_minmax(0,1fr)] max-h-[800px] overflow-y-auto"><div class="bg-gray-50 border-b border-r border-gray-200 sticky top-0 z-20" style="height:32px"></div><div class="bg-gray-50 border-b border-gray-200 sticky top-0 z-10" style="height:32px"></div><div class="border-r border-gray-200 bg-white"><div style="height:32px" aria-hidden="true"></div><div class="flex items-center px-3 border-b border-gray-100 last:border-b-0" style="height:28px;padding-left:12px;padding-right:12px"><span class="flex items-center gap-2 truncate"><span aria-hidden="true" class="text-[14px] leading-none shrink-0">🇩🇪</span><span class="truncate text-xs sm:text-sm font-medium text-gray-800">Germany</span><span class="text-[10px] text-gray-400 shrink-0 hidden sm:inline">DE</span></span></div><div class="flex items-center px-3 border-b border-gray-100 last:border-b-0" style="height:28px;padding-left:12px;padding-right:12px"><span class="flex items-center gap-2 truncate"><span aria-hidden="true" class="text-[14px] leading-none shrink-0">🇦🇹</span><span class="truncate text-xs sm:text-sm font-medium text-gray-800">Austria</span><span class="text-[10px] text-gray-400 shrink-0 hidden sm:inline">AT</span></span></div><div class="flex items-center px-3 border-b border-gray-100 last:border-b-0" style="height:28px;padding-left:12px;padding-right:12px"><span class="flex items-center gap-2 truncate"><span aria-hidden="true" class="text-[14px] leading-none shrink-0">🇳🇱</span><span class="truncate text-xs sm:text-sm font-medium text-gray-800">Netherlands</span><span class="text-[10px] text-gray-400 shrink-0 hidden sm:inline">NL</span></span></div><div style="height:22px"></div><