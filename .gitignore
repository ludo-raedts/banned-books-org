# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*-run.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code
.claude/*
# share the project-level settings, keep personal settings/worktrees local
!.claude/settings.json

# supabase temp
supabase/.temp/
supabase/.branches/

# ad-hoc throwaway scripts (prefix _ marks one-off check/find/inspect helpers
# that should never be committed; real scripts use kebab-case without prefix)
scripts/_*.ts

# typescript
*.tsbuildinfo
next-env.d.ts

# generated dataset zip (regenerated by `pnpm build:dataset`, never committed)
/private/

# editorial classifier run artifacts (timestamped per run)
/data/editorial-review-*.json

# bookshop curated-list payloads (regenerated by scripts/export-bookshop-lists.ts)
/data/bookshop-lists/

# enrichment / audit script outputs (timestamped per run, local-only)
/data/description-*.csv
/data/filler-strip-*.csv
/data/photo-enrichment-*.csv
/data/clean-descriptions-top-slugs-*.txt

# resumable-script state — regenerated on every run
/data/*.state.json

# wikipedia bulk-parser run artifacts (timestamped per run, local-only)
/data/wikipedia-import-runs/

# Google Search Console query dumps (local-only, regenerated on demand)
/data/gsc/

# The Literature Police PDFs (Western Cape Provincial Archives, via P.D. McDonald).
# Re-fetchable from https://theliteraturepolice.com/documents/ — filenames are
# pinned in scripts/import-literature-police.ts and ban_sources.source_url.
/data/literature-police-pdfs/

# editorial-suggest + ad-hoc run logs (timestamped per run, local-only)
/data/logs/

# wikipedia enrichment pipeline runtime artifacts — staging output (step B),
# worklist (step A) and apply-log (step C) are all regenerated by the scripts.
# Overrides JSON is curated input and IS committed.
/data/wiki-enrichment-staging/
/data/wiki-enrichment-worklist.json
/data/wiki-enrichment-worklist.md
/data/wiki-enrichment-applied.log

# ad-hoc merge-audit dumps (regenerated by merge scripts)
/data/merge-*.json

# enrichment run logs and firecrawl outputs (timestamped/resumable per run, local-only)
/data/*-log.txt
/data/firecrawl-*.csv
/data/*-state.json
