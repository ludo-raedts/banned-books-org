# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*-run.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code
.claude/*
# share the project-level settings, keep personal settings/worktrees local
!.claude/settings.json

# supabase temp
supabase/.temp/
supabase/.branches/

# ad-hoc throwaway scripts (prefix _ marks one-off check/find/inspect helpers
# that should never be committed; real scripts use kebab-case without prefix)
scripts/_*.ts

# typescript
*.tsbuildinfo
next-env.d.ts

# generated dataset zip (regenerated by `pnpm build:dataset`, never committed)
/private/

# editorial classifier run artifacts (timestamped per run)
/data/editorial-review-*.json

# bookshop curated-list payloads (regenerated by scripts/export-bookshop-lists.ts)
/data/bookshop-lists/

# enrichment / audit script outputs (timestamped per run, local-only)
/data/description-*.csv
/data/filler-strip-*.csv
/data/photo-enrichment-*.csv
/data/clean-descriptions-top-slugs-*.txt

# resumable-script state — regenerated on every run
/data/*.state.json

# wikipedia bulk-parser run artifacts (timestamped per run, local-only)
/data/wikipedia-import-runs/

# Google Search Console query dumps (local-only, regenerated on demand)
/data/gsc/

# The Literature Police PDFs (Western Cape Provincial Archives, via P.D. McDonald).
# Re-fetchable from https://theliteraturepolice.com/documents/ — filenames are
# pinned in scripts/import-literature-police.ts and ban_sources.source_url.
/data/literature-police-pdfs/

# editorial-suggest + ad-hoc run logs (timestamped per run, local-only)
/data/logs/

# wikipedia enrichment pipeline runtime artifacts — staging output (step B),
# worklist (step A) and apply-log (step C) are all regenerated by the scripts.
# Overrides JSON is curated input and IS committed.
/data/wiki-enrichment-staging/
/data/wiki-enrichment-worklist.json
/data/wiki-enrichment-worklist.md
/data/wiki-enrichment-applied.log

# ad-hoc merge-audit dumps (regenerated by merge scripts)
/data/merge-*.json

# enrichment run logs and firecrawl outputs (timestamped/resumable per run, local-only)
/data/*-log.txt
/data/firecrawl-*.csv
/data/*-state.json
/.firecrawl/

# per-run rejection logs (timestamped, local-only audit trail)
/data/*-rejected-*.jsonl

# large regenerable audit intermediate (rebuilt by audit-publication-years.ts)
/data/publication-year-audit.json

# generated visual-check montage (rebuilt by _montage_google_covers.ts)
/public/cover-montage.html
/public/shared-cover-suspects.html

# author-bio remediation run artifacts (timestamped per run, local-only;
# the contamination-audit .md IS committed)
/data/author-bio-remediation-*
/data/author-ol-writes-*.csv
/data/*.state.json.bak*

# OL/GB harvest runtime artifacts — cursors, proposals, run logs
# (launchd job org.banned-books.gb-harvest writes these continuously)
/data/ol-harvest-*
/data/gb-harvest-*

# LLM year-verification cascade — resume checkpoint (.jsonl) + derived
# report (.json, read by resolve-proposed-years.ts); expensive cache, local-only
/data/year-llm-verification.json
/data/year-llm-verification.jsonl
/data/resolve-proposed-years.json
/data/resolve-proposed-years.jsonl

# cover vision-audit / recovery machine outputs (.md report IS committed)
/data/cover-vision-audit.json
/data/cover-vision-audit.jsonl
/data/cover-recovery.json
/data/cover-recovery.jsonl

# OL-contamination remediation inputs (regenerated by _audit_ol_contamination.ts)
/data/ol-contamination-remediation.csv
/data/ol-contamination-worklist.json

# consensus-description run artifacts (timestamped per run, local-only)
/data/consensus-descriptions-*
/data/consensus-desc-validation.jsonl

# reground (fase 2) run artifacts — backups, worklists, logs (timestamped per run)
/data/_reground_*.log
/data/reground-noisbn-*

# leading-underscore = local scratch (run logs, snapshots, grounding dumps)
/data/_*
# row backups taken before destructive merges/wipes (local-only safety copies)
/data/vague-pen-rollups-backup-*
/data/wiped-*-backup.csv
# press-release source/draft material (local-only)
/data/press-release-data-*
